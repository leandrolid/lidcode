{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "sourceRoot": "src",
  "entryFile": "index",
  "language": "ts",
  "compilerOptions": {
    "tsConfigPath": "./tsconfig.build.json",
    "deleteOutDir": true,
    "assets": [
      "static/**/*"
    ],
    "watchAssets": true
  }
}
