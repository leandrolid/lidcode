{
  "extends": "@lidcode/tsconfig/base.json",
  "include": [
    "src"
  ],
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2024",
    "sourceMap": true,
    "outDir": "./dist",
    "skipLibCheck": true,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@infra/*": [
        "src/infra/*"
      ],
      "@app/*": [
        "src/app/*"
      ],
      "@domain/*": [
        "src/domain/*"
      ],
      "@/*": [
        "src/*"
      ]
    }
  }
}