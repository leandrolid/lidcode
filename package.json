{
  "name": "shortlid",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:local": "dotenv -e .env -- turbo run build",
    "dev": "dotenv -e .env -- turbo run dev --log-prefix=none",
    "start:dev": "dotenv -e .env -- turbo run start:dev",
    "migrate:dev": "dotenv -e .env -- turbo run migrate:dev",
    "migrate:deploy": "dotenv -e .env -- turbo run migrate:deploy",
    "seed:dev": "dotenv -e .env -- turbo run seed:dev",
    "generate:dev": "dotenv -e .env -- turbo run generate:dev",
    "db:open": "dotenv -e .env -- turbo run db:open",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "dotenv-cli": "^10.0.0",
    "turbo": "^2.6.3",
    "typescript": "5.8.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@9.8.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
